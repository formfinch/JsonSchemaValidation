{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "user": {
      "type": "object",
      "properties": {
        "profile": {
          "type": "object",
          "properties": {
            "firstName": { "type": "string" },
            "lastName": { "type": "string" },
            "age": { "type": "integer" }
          },
          "required": ["firstName", "lastName"]
        },
        "settings": {
          "type": "object",
          "properties": {
            "notifications": { "type": "boolean" },
            "theme": { "type": "string", "enum": ["light", "dark"] }
          }
        }
      },
      "required": ["profile"]
    }
  },
  "required": ["user"]
}
